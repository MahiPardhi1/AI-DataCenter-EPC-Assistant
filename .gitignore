gitignore
# ==========================
# Python
# ==========================
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/
ENV/

# Environment Variables
.env
.env.*
!.env.example

# ==========================
# VS Code
# ==========================
.vscode/

# ==========================
# Jupyter
# ==========================
.ipynb_checkpoints/

# ==========================
# ChromaDB (Generated Vector Database)
# ==========================
chroma_db/
project_data/chroma_db/

# ==========================
# Logs
# ==========================
*.log

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Build Files
# ==========================
build/
dist/
*.egg-info/

# ==========================
# Python Cache
# ==========================
.pytest_cache/
.mypy_cache/

# ==========================
# Temporary Files
# ==========================
*.tmp
*.bak
*.__ocr_tmp.png

# ==========================
# IDE
# ==========================
.idea/

# ==========================
# Model Files (Ignore large models if generated)
# ==========================
*.pth
*.pt
*.ckpt

# ==========================
# Keep Dataset PDFs & CSVs
# (Do NOT ignore project_data/ itself)
# ==========================

# YOLO generated outputs
runs/
compliance_report.csv
compliance_report_eval_metrics.csv
compliance_report_confusion_matrix.csv
supply_chain_dashboard.html
supply_chain_dashboard.json
schedule_dashboard.html
schedule_dashboard.json
reports/